<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Calculator</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <main class="app">
    <section class="calculator-panel">
      <div style="display:flex; justify-content:space-between; align-items:center; gap:1rem; margin-bottom:1rem;">
        <h1 style="margin:0;">Simple Calculator</h1>
        <div style="display:flex; gap:0.5rem; align-items:center;">
          <a href="/dashboard" style="color:#2563eb; text-decoration:none;">Dashboard</a>
          <a href="/logout" style="color:#2563eb; text-decoration:none;">Logout</a>
        </div>
      </div>
      <form action="/calculate" method="POST" class="calculator-form">
        <input type="text" name="expression" id="expression" placeholder="Enter expression" required>
        <button type="submit">Calculate</button>
      </form>
      <div class="quick-buttons">
        <button onclick="appendValue('7')">7</button>
        <button onclick="appendValue('8')">8</button>
        <button onclick="appendValue('9')">9</button>
        <button onclick="appendValue('/')">/</button>
        <button onclick="appendValue('4')">4</button>
        <button onclick="appendValue('5')">5</button>
        <button onclick="appendValue('6')">6</button>
        <button onclick="appendValue('*')">*</button>
        <button onclick="appendValue('1')">1</button>
        <button onclick="appendValue('2')">2</button>
        <button onclick="appendValue('3')">3</button>
        <button onclick="appendValue('-')">-</button>
        <button onclick="appendValue('0')">0</button>
        <button onclick="appendValue('.')">.</button>
        <button onclick="appendValue('+')">+</button>
        <button onclick="clearInput()">C</button>
      </div>
    </section>

    <section class="history-panel">
      <h2>Recent History</h2>
      <% if (history.length === 0) { %>
        <p>No calculations yet.</p>
      <% } else { %>
        <ul>
          <% history.forEach(item => { %>
            <li>
              <span><%= item.expression %></span>
              <strong>= <%= item.result %></strong>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </section>
  </main>

  <script>
    const expressionInput = document.getElementById('expression');

    function appendValue(value) {
      expressionInput.value += value;
      expressionInput.focus();
    }

    function clearInput() {
      expressionInput.value = '';
      expressionInput.focus();
    }
  </script>
</body>
</html>
